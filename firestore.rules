rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerifiedUser() {
      return isSignedIn();
    }

    // Entity validation helpers
    function isValidArtist(data) {
      return data.keys().hasAll(['displayName', 'createdAt']) &&
        data.displayName is string &&
        data.displayName.size() >= 2 &&
        data.displayName.size() <= 50 &&
        data.createdAt == request.time &&
        (!data.keys().hasAny(['bio']) || (data.bio is string && data.bio.size() <= 300)) &&
        (!data.keys().hasAny(['avatarUrl']) || (data.avatarUrl is string && data.avatarUrl.size() <= 2048));
    }

    function isValidArtistPrivate(data) {
      return data.keys().hasAll(['email', 'updatedAt']) &&
        data.email is string &&
        data.email.size() <= 254 &&
        data.updatedAt == request.time &&
        (!data.keys().hasAny(['stripeAccountId']) || (data.stripeAccountId is string && data.stripeAccountId.size() <= 100));
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['artistId', 'title', 'type', 'status', 'currentAmount', 'createdAt', 'updatedAt']) &&
        data.artistId is string &&
        isValidId(data.artistId) &&
        data.title is string &&
        data.title.size() >= 3 &&
        data.title.size() <= 100 &&
        (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 500)) &&
        data.type is string &&
        (data.type == 'live' || data.type == 'fundraiser') &&
        data.status is string &&
        (data.status == 'active' || data.status == 'completed') &&
        data.currentAmount is number &&
        data.currentAmount >= 0 &&
        (!data.keys().hasAny(['targetAmount']) || (data.targetAmount is number && data.targetAmount >= 0)) &&
        data.createdAt == request.time &&
        data.updatedAt == request.time;
    }

    function isValidTip(data) {
      return data.keys().hasAll(['artistId', 'eventId', 'amount', 'fanName', 'timestamp']) &&
        data.artistId is string &&
        isValidId(data.artistId) &&
        data.eventId is string &&
        isValidId(data.eventId) &&
        data.amount is number &&
        data.amount > 0 &&
        data.amount <= 10000 &&
        data.fanName is string &&
        data.fanName.size() >= 1 &&
        data.fanName.size() <= 50 &&
        (!data.keys().hasAny(['message']) || (data.message is string && data.message.size() <= 200)) &&
        data.timestamp == request.time;
    }

    // Collection: Artists (Public Profiles)
    match /artists/{artistId} {
      allow read: if true;
      allow create: if isOwner(artistId) && isVerifiedUser() && isValidArtist(incoming());
      allow update: if isOwner(artistId) && isVerifiedUser() && isValidArtist(incoming()) && incoming().createdAt == existing().createdAt;

      // Collection: Artist Private Settings (PII / Settings Isolation)
      match /private/settings {
        allow read: if isOwner(artistId) && isVerifiedUser();
        allow create: if isOwner(artistId) && isVerifiedUser() && isValidArtistPrivate(incoming());
        allow update: if isOwner(artistId) && isVerifiedUser() && isValidArtistPrivate(incoming());
      }
    }

    // Collection: Events (Live Sets / Fundraisers)
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(incoming().artistId) && isVerifiedUser() && isValidId(eventId) && isValidEvent(incoming());
      
      // Update has two paths: 
      // 1. The artist updating details (only while active, following terminal state locking)
      // 2. A fan incrementing currentAmount as part of a tip transaction batch
      allow update: if isValidId(eventId) && (
        // Path 1: Artist Admin
        (
          isSignedIn() && 
          isOwner(existing().artistId) && 
          isVerifiedUser() && 
          isValidEvent(incoming()) && 
          incoming().artistId == existing().artistId && 
          incoming().createdAt == existing().createdAt && 
          existing().status == 'active' &&
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'status', 'targetAmount', 'updatedAt'])
        ) ||
        // Path 2: Fan Tipping Batch
        (
          isValidEvent(incoming()) && 
          incoming().artistId == existing().artistId && 
          incoming().createdAt == existing().createdAt && 
          incoming().title == existing().title && 
          incoming().get('description', null) == existing().get('description', null) && 
          incoming().type == existing().type && 
          incoming().status == existing().status && 
          incoming().get('targetAmount', null) == existing().get('targetAmount', null) && 
          incoming().currentAmount > existing().currentAmount && 
          incoming().diff(existing()).affectedKeys().hasOnly(['currentAmount', 'updatedAt'])
        )
      );

      allow delete: if isSignedIn() && isOwner(existing().artistId) && isVerifiedUser() && existing().status == 'active';
    }

    // Collection: Tips
    match /tips/{tipId} {
      allow read: if true;
      allow create: if isValidId(tipId) && isValidTip(incoming()) &&
        // Relational sync: The event must be active and match the artist
        get(/databases/$(database)/documents/events/$(incoming().eventId)).data.status == 'active' &&
        get(/databases/$(database)/documents/events/$(incoming().eventId)).data.artistId == incoming().artistId &&
        // Atomicity Guarantee: Event currentAmount must be incremented by the tip amount
        getAfter(/databases/$(database)/documents/events/$(incoming().eventId)).data.currentAmount == 
          get(/databases/$(database)/documents/events/$(incoming().eventId)).data.currentAmount + incoming().amount;

      // Tips are immutable: Updates and deletes are blocked
      allow update, delete: if false;
    }
  }
}
